{
  "name": "code-assistant",
  "displayName": "Code Assistant",
  "description": "算法学习插件-吉祥物Live2D看板娘。 陪伴你学习算法，给予鼓励和支持",
  "version": "2.0.0",
  "author": "dim273",
  "publisher": "dim273",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dim273/t-pet"
  },
  "engines": {
    "vscode": "^1.98.2"
  },
  "keywords": [
    "algorithm",
    "learning",
    "算法学习",
    "live2d",
    "看板娘",
    "能力图谱",
    "教育",
    "编程学习"
  ],
  "icon": "logo.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*",
    "onView:vscode-live2d.live2dView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "vscode-live2d.live2dView",
          "name": "code-assistant"
        }
      ]
    },
    "configuration": [
      {
        "title": "看板娘配置",
        "type": "Object",
        "properties": {
          "vscode-live2d-asoul.enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用live2d-asoul"
          }
        }
      },
      {
        "title": "AI助手配置",
        "type": "Object",
        "properties": {
          "t-pet.deepseekApiKey": {
            "type": "string",
            "default": "",
            "description": "DeepSeek API Key (从 api.deepseek.com 获取)"
          },
          "t-pet.deepseekModel": {
            "type": "string",
            "default": "deepseek-v4-pro",
            "description": "DeepSeek 模型名称"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "echo 'Skipping compile - using pre-built out directory'",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "yarn run compile && yarn run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "mocha \"tests/**/*.test.mjs\"",
    "coverage": "c8 --reporter=text --reporter=lcov mocha \"tests/**/*.test.mjs\"",
    "build": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^7.1.4",
    "@types/mocha": "^9.0.0",
    "@types/node": "14.x",
    "@types/vscode": "^1.47.0",
    "@typescript-eslint/eslint-plugin": "^4.31.1",
    "@typescript-eslint/parser": "^4.31.1",
    "@vscode/test-electron": "^1.6.2",
    "c8": "^10.1.3",
    "eslint": "^7.32.0",
    "glob": "^7.1.7",
    "mocha": "^9.1.1",
    "typescript": "^4.4.3"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "jsdom": "^28.0.0",
    "request": "^2.88.2",
    "request-promise": "^4.2.6",
    "turndown": "^7.2.2"
  }
}